---
import '../styles/global.css';
import { content as allContent, locales } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const c = allContent[lang];
const loc = locales[lang];

const site = Astro.site?.href.replace(/\/$/, '') ?? 'https://rise-advisory.com';
const canonical = new URL(loc.path, Astro.site).href;
const ogImage = `${site}/og-image.png`;
const orgId = `${site}/#organization`;

const alternates = [
  { hreflang: 'en', href: `${site}/` },
  { hreflang: 'ar', href: `${site}/ar/` },
  { hreflang: 'x-default', href: `${site}/` },
];
const ogLocale = lang === 'ar' ? 'ar_KW' : 'en_US';
const ogLocaleAlt = lang === 'ar' ? 'en_US' : 'ar_KW';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfessionalService',
      '@id': orgId,
      name: 'Rise Advisory',
      alternateName: 'رايز للاستشارات',
      description: c.meta.description,
      url: `${site}/`,
      logo: `${site}/og-image.png`,
      image: ogImage,
      email: 'info@rise-advisory.com',
      priceRange: '$$',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Block 5, Parcel 41, Group A Building, Floor 9',
        addressLocality: 'Sharq',
        addressCountry: 'KW',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 29.37375853181783,
        longitude: 47.98977880183676,
      },
      hasMap: 'https://maps.app.goo.gl/RCqhJW1xwHWs98Er6',
      areaServed: { '@type': 'Country', name: 'Kuwait' },
      contactPoint: {
        '@type': 'ContactPoint',
        email: 'info@rise-advisory.com',
        contactType: 'customer service',
        availableLanguage: ['English', 'Arabic'],
      },
      sameAs: [
        'https://www.instagram.com/riseadvisory/',
        'https://maps.google.com/?cid=2917434890951246542',
      ],
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'Advisory Services',
        itemListElement: c.services.items.map((s) => ({
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: s.title,
            description: s.body,
            provider: { '@id': orgId },
            areaServed: { '@type': 'Country', name: 'Kuwait' },
          },
        })),
      },
    },
    {
      '@type': 'WebSite',
      '@id': `${site}/#website`,
      name: 'Rise Advisory',
      url: `${site}/`,
      publisher: { '@id': orgId },
      inLanguage: ['en', 'ar'],
    },
    {
      '@type': 'WebPage',
      '@id': canonical,
      name: c.meta.title,
      url: canonical,
      isPartOf: { '@id': `${site}/#website` },
      about: { '@id': orgId },
      inLanguage: lang,
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonical}#faq`,
      inLanguage: lang,
      mainEntity: c.faq.items.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    },
  ],
};
---

<!doctype html>
<html lang={loc.htmlLang} dir={loc.dir} class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <title>{c.meta.title}</title>
    <meta name="description" content={c.meta.description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <!-- Language alternates -->
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}

    <!-- Local / geo signals (Kuwait) -->
    <meta name="geo.region" content="KW" />
    <meta name="geo.placename" content="Kuwait City" />
    <meta name="geo.position" content="29.373759;47.989779" />
    <meta name="ICBM" content="29.373759, 47.989779" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={c.meta.title} />
    <meta property="og:description" content={c.meta.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Rise Advisory" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={c.meta.title} />
    <meta name="twitter:description" content={c.meta.description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {
      lang === 'ar' ? (
        <link
          href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Tajawal:wght@300;400;500;700&display=swap"
          rel="stylesheet"
        />
      ) : (
        <Fragment>
          <link
            href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700&display=swap"
            rel="stylesheet"
          />
          <link rel="preload" href="/fonts/rise-heading.woff2" as="font" type="font/woff2" crossorigin />
          <link rel="preload" href="/fonts/didot-w01-italic.woff2" as="font" type="font/woff2" crossorigin />
        </Fragment>
      )
    }

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-full">
    <slot />
  </body>
</html>
