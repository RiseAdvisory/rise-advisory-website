---
import type { Content } from '../i18n';

interface Props {
  content: Content['about'];
}
const { content } = Astro.props;
---

<section id="about" class="w-full bg-white">
  <div class="mx-auto w-full max-w-6xl px-6 py-24 md:py-28 lg:px-8">
    <div class="grid gap-12 md:grid-cols-[0.8fr_1.2fr] md:gap-16">
      <div>
        <p class="eyebrow mb-5 text-muted">{content.eyebrow}</p>
        <h2 class="text-balance text-3xl font-normal leading-[1.2] text-ink md:text-4xl">
          {content.h2}
        </h2>
      </div>

      <div class="max-w-2xl">
        <p class="text-lg leading-[1.85] text-ink/90">{content.p1}</p>
        <p class="mt-6 text-lg leading-[1.85] text-ink/90">{content.p2}</p>

        <div class="mt-12 grid gap-8 border-t border-line/60 pt-10 sm:grid-cols-2">
          <div>
            <p class="eyebrow mb-3 text-muted">{content.visionLabel}</p>
            <p class="font-heading text-xl leading-[1.45] text-ink">{content.vision}</p>
          </div>
          <div>
            <p class="eyebrow mb-3 text-muted">{content.missionLabel}</p>
            <p class="font-heading text-xl leading-[1.45] text-ink">{content.mission}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
