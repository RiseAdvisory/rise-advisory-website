---
import type { Content } from '../i18n';

interface Props {
  content: Content['hero'];
}
const { content } = Astro.props;
---

<section id="top" class="w-full bg-navy text-white">
  <div class="mx-auto w-full max-w-6xl px-6 py-24 md:py-32 lg:px-8">
    <div class="max-w-3xl">
      <h1 class="text-balance text-4xl font-normal leading-[1.12] text-white md:text-6xl">
        {content.h1}
      </h1>
      <p class="mt-8 max-w-2xl text-lg leading-[1.7] text-white/85 md:text-xl">
        {content.body}
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-x-7 gap-y-4">
        <a href="#contact" class="btn-solid bg-white text-base text-ink">
          {content.ctaPrimary}
        </a>
        <a href="#approach" class="btn-link border-white/40 text-base text-white hover:border-white">
          {content.ctaSecondary}
        </a>
      </div>
    </div>
  </div>
</section>
