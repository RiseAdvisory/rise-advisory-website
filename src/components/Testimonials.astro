---
import type { Content } from '../i18n';

interface Props {
  content: Content['testimonials'];
}
const { content } = Astro.props;
---

<section id="clients" class="w-full bg-surface">
  <div class="mx-auto w-full max-w-6xl px-6 py-24 md:py-28 lg:px-8">
    <div class="max-w-2xl">
      <p class="eyebrow mb-5 text-muted">{content.eyebrow}</p>
      <h2 class="text-balance text-3xl font-normal leading-[1.2] text-ink md:text-4xl">
        {content.h2}
      </h2>
    </div>

    <div class="mt-14 grid gap-px bg-line/60 md:grid-cols-2">
      {
        content.items.map((t) => (
          <figure class="flex flex-col bg-surface px-2 py-10 md:px-10">
            <blockquote class="text-lg leading-[1.85] text-ink/90">
              &ldquo;{t.quote}&rdquo;
            </blockquote>
            <figcaption class="mt-6">
              <p class="font-heading text-lg text-ink">{t.name}</p>
              <p class="mt-1 text-sm uppercase tracking-[0.14em] text-muted">{t.role}</p>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
