<section id="contact" class="w-full bg-navy text-white">
  <div class="mx-auto w-full max-w-6xl px-6 py-24 md:py-28 lg:px-8">
    <div class="grid gap-14 md:grid-cols-2 md:gap-16">
      <div>
        <h2 class="text-balance text-3xl font-normal leading-[1.18] md:text-4xl">
          Start with a conversation
        </h2>
        <p class="mt-6 max-w-md text-lg leading-[1.8] text-white/85">
          Tell us what you are dealing with. We will listen, then let you know
          whether and how we can help.
        </p>
      </div>

      <div class="flex flex-col">
        <p class="eyebrow mb-3 text-white/60">Email us</p>
        <p class="max-w-md text-lg leading-[1.8] text-white/85">
          The best way to reach us is by email. Write to us and we will get back
          to you.
        </p>
        <a
          href="mailto:info@rise-advisory.com"
          class="btn-solid mt-7 w-fit bg-white text-base text-ink"
        >
          info@rise-advisory.com
        </a>

        <div class="mt-12 border-t border-white/15 pt-8">
          <p class="eyebrow mb-1 text-white/60">Office</p>
          <a
            href="https://maps.app.goo.gl/RCqhJW1xwHWs98Er6"
            target="_blank"
            rel="noreferrer noopener"
            class="leading-[1.7] text-white/90 transition-colors hover:text-white"
          >
            Kuwait, Sharq, Block 5, Parcel 41,<br />
            Group A Building, Floor 9
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
